# CampusShare Docker 环境变量配置
# 复制此文件为 .env 并填写真实值：cp .env.example .env

# ========== QQ 邮箱 ==========
# 1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 SMTP 服务
# 2. 获取授权码（不是 QQ 密码）
# MAIL_HOST=smtp.qq.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@qq.com
# MAIL_PASSWORD=your-smtp-authorization-code

# ========== Outlook 邮箱 ==========
# 直接使用邮箱密码即可（无需授权码）
MAIL_HOST=smtp-mail.outlook.com
MAIL_PORT=587
MAIL_USERNAME=your-email@outlook.com
MAIL_PASSWORD=your-email-password

# ========== Agent Service ==========
# DeepSeek API（官方地址 https://api.deepseek.com 或自建代理地址）
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 豆包 API（兜底，暂未启用）
DOUBAO_API_KEY=your-doubao-key

# Embedding 服务（硅基流动 SiliconFlow，BGE-M3 模型）
EMBEDDING_API_KEY=sk-your-siliconflow-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn

# Agent PostgreSQL 密码
AGENT_PG_PASSWORD=agent123456

# 服务间内部 API 鉴权 token
INTERNAL_API_TOKEN=campushare-internal-token
